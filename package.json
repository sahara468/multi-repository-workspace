{
  "name": "mrw",
  "version": "0.1.0",
  "description": "Multi-Repository Workspace - CLI tool for managing multiple microservice repositories as a unified business workspace",
  "type": "module",
  "bin": {
    "mrw": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsx build.ts",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src/ && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "eslint src/ && tsc --noEmit && vitest run --coverage",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "multi-repo",
    "workspace",
    "microservices",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.23",
    "ora": "^8.0.1",
    "simple-git": "^3.27.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.21.5",
    "eslint": "^10.2.1",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
